.page {
  padding: 16px 0 0;
}

.dialog-box {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 20px;
  max-height: 85vh;
  overflow-y: auto;
}

.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 8vh;
  z-index: 999;
}

/* 团队头部 */
.team-header {
  display: flex;
  gap: 16px;
  padding: 0 16px 0;
  align-items: flex-start;
}

.share-btn {
  flex-shrink: 0;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 50%;
  width: 32px !important;
  height: 32px !important;
  min-height: 0 !important;
  padding: 0 !important;
  margin: 2px 0 0 auto !important;
  font-size: 16px !important;
  line-height: 32px !important;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.share-btn::after {
  border: none !important;
}

.th-actions {
  display: flex;
  flex-direction: column;
  gap: 6px;
  align-items: center;
  flex-shrink: 0;
}

.th-edit-btn, .th-archive-btn, .th-restore-btn {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 10px;
  text-align: center;
}
.th-edit-btn { color: var(--primary-light); border: 1px solid var(--primary); }
.th-archive-btn { color: var(--accent-red); border: 1px solid var(--accent-red); }
.th-restore-btn { color: var(--accent-green); border: 1px solid var(--accent-green); }
.th-leave-btn { color: var(--text-muted); border: 1px solid var(--border); }

.th-avatar {
  width: 64px;
  height: 64px;
  border-radius: 16px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.th-info {
  flex: 1;
}

.th-name {
  font-size: 22px;
  font-weight: 700;
  display: block;
}

.th-desc {
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 4px;
  display: block;
}

.th-meta {
  display: flex;
  gap: 16px;
  margin-top: 8px;
  font-size: 12px;
  color: var(--text-muted);
}

/* Tab */
.tab-row {
  display: flex;
  gap: 0;
  padding: 0 16px 4px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px;
  font-size: 15px;
  color: var(--text-secondary);
  border-bottom: 2px solid transparent;
}

.tab-active {
  color: var(--primary-light);
  border-bottom-color: var(--primary);
  font-weight: 600;
}

/* 添加活动/公告 */
.add-activity-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  border: 2px dashed var(--border);
}

/* 活动卡片 */
.activity-card {
  margin-bottom: 10px;
}

.ac-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.ac-title {
  font-size: 16px;
  font-weight: 600;
  flex: 1;
}

.ac-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 8px;
}

.ac-meta {
  font-size: 13px;
  color: var(--text-secondary);
}

.ac-desc {
  font-size: 13px;
  color: var(--text-secondary);
  padding: 8px;
  background: rgba(255,255,255,0.04);
  border-radius: 6px;
  margin-bottom: 8px;
}

.ac-stats {
  display: flex;
  gap: 16px;
  margin-bottom: 10px;
}

.ac-stat {
  font-size: 12px;
  color: var(--text-muted);
}

.ac-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}

.ac-btn {
  padding: 4px 10px !important;
  font-size: 12px !important;
  min-height: 0 !important;
  line-height: 1.6 !important;
  height: auto !important;
}

.ac-checked-tag {
  font-size: 13px;
}

.ac-cancel {
  font-size: 12px;
  color: var(--accent-red);
  margin-left: auto;
}

/* 评论区域 */
.ac-comment-toggle {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid rgba(255,255,255,0.06);
  font-size: 13px;
  color: var(--text-secondary);
}

.ac-comment-count {
  font-size: 12px;
  color: var(--text-muted);
}

.ac-comment-section {
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.ac-comment-item {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
  font-size: 13px;
}

.ac-comment-user {
  color: var(--primary-light);
  font-weight: 500;
  flex-shrink: 0;
}

.ac-comment-text {
  color: var(--text-primary);
  flex: 1;
}

.ac-comment-input-row {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.ac-comment-input {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 8px 12px;
  font-size: 13px;
  color: var(--text-primary);
  height: 36px;
}

.ac-comment-send {
  padding: 6px 12px;
  font-size: 12px;
  flex-shrink: 0;
}

/* 公告卡片 */
.announcement-card {
  margin-bottom: 10px;
}

.ann-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.ann-title {
  font-size: 16px;
  font-weight: 600;
  flex: 1;
}

.ann-content {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 8px;
  white-space: pre-wrap;
}

.ann-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text-muted);
}

/* 成员卡片 */
.member-card {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 6px;
  padding: 12px 16px;
}

.mc-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(108,99,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  color: var(--primary-light);
  flex-shrink: 0;
}

.mc-info {
  flex: 1;
}

.mc-name {
  font-size: 14px;
  font-weight: 500;
  display: block;
}

.mc-role {
  font-size: 12px;
  color: var(--text-muted);
  display: block;
  margin-top: 2px;
}

.empty-state {
  text-align: center;
  padding: 40px 16px;
}

.empty-text {
  font-size: 16px;
  color: var(--text-secondary);
}

.empty-sub {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 8px;
  display: block;
}

.form-group {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 6px;
  display: block;
}

.picker-value {
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 12px 16px;
  font-size: 15px;
  color: var(--text-primary);
}

.dt-row { display: flex; gap: 10px; }
.dt-date { flex: 3; }
.dt-time { flex: 2; }

.dialog-wide {
  width: 90%;
  max-width: 400px;
}

/* === 留言弹窗 === */
.msg-list {
  max-height: 50vh;
  overflow-y: auto;
  margin-bottom: 8px;
}

.msg-item {
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.msg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.msg-author {
  font-size: 13px;
  font-weight: 600;
  color: var(--primary-light);
}

.msg-delete {
  font-size: 12px;
  color: var(--accent-red);
  padding: 4px 8px;
}

.msg-content {
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.5;
  display: block;
}

.msg-time {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 4px;
  display: block;
}

.msg-empty {
  text-align: center;
  padding: 24px 0;
}

.msg-input-row {
  display: flex;
  gap: 8px;
  padding-top: 8px;
  border-top: 1px solid rgba(255,255,255,0.06);
}

.msg-input {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 8px 12px;
  font-size: 13px;
  color: var(--text-primary);
  height: 36px;
}

.msg-send {
  padding: 6px 12px;
  font-size: 12px;
  flex-shrink: 0;
}
