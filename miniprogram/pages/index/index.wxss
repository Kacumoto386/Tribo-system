.page {
  padding: 20px 0 100px;
  position: relative;
}

/* ====== 顶部问候 ====== */
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px;
  margin-bottom: 16px;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 14px;
}

.bell-wrap {
  position: relative;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.bell-icon { font-size: 22px; }
.bell-badge {
  position: absolute;
  top: 2px;
  right: 2px;
  min-width: 18px;
  height: 18px;
  background: var(--accent-red);
  color: white;
  font-size: 11px;
  font-weight: 600;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4px;
}

.greeting-text {
  font-size: 22px;
  font-weight: 700;
  display: block;
}

.date-text {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 4px;
  display: block;
}

.avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #ff6b9d);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 18px;
  font-weight: 700;
  color: white;
}

/* ====== 快速入口 ====== */
.quick-grid {
  display: flex;
  gap: 10px;
  padding: 0 16px;
  margin-bottom: 16px;
}

.quick-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 12px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.quick-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.icon-box {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}
.icon-box-text { line-height: 1; }

.icon-box.quick-blue { background: rgba(74,144,226,0.15); }
.icon-box.quick-orange { background: rgba(255,159,64,0.15); }
.icon-box.quick-purple { background: rgba(108,99,255,0.15); }

.quick-label {
  font-size: 12px;
  color: var(--text-secondary);
  font-weight: 500;
}

/* ====== 卡片头部 ====== */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.card-create {
  font-size: 13px;
  color: var(--accent-green);
  font-weight: 500;
}

.card-more {
  font-size: 13px;
  color: var(--primary-light);
}

/* ====== 团队列表 ====== */
.team-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.team-row:last-child {
  border-bottom: none;
}

.team-avatar {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.team-avatar-text {
  color: white;
  font-size: 18px;
  font-weight: 700;
}

.team-info {
  flex: 1;
  min-width: 0;
}

.team-name {
  font-size: 15px;
  font-weight: 600;
  display: block;
}

.team-desc {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 2px;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ====== 活动列表 ====== */
.activity-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.activity-row:last-child {
  border-bottom: none;
}

.activity-icon-wrap {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: rgba(108,99,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.activity-icon {
  font-size: 18px;
}

.activity-info {
  flex: 1;
  min-width: 0;
}

.activity-title {
  font-size: 14px;
  font-weight: 500;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.activity-meta {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 2px;
  display: block;
}

/* ====== Feed 动态 ====== */
.feed-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.feed-row:last-child {
  border-bottom: none;
}

.feed-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: rgba(108,99,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 17px;
}
.feed-icon text {
  line-height: 1;
  display: block;
}

.feed-info {
  flex: 1;
  min-width: 0;
}

.feed-text {
  font-size: 14px;
  font-weight: 500;
  display: block;
  line-height: 1.4;
}

.feed-time {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 4px;
  display: block;
}

/* ====== 空状态 ====== */
.empty-mini {
  text-align: center;
  padding: 16px 0;
}

.empty-text-mini {
  font-size: 13px;
  color: var(--text-muted);
}

/* ====== 待办聚合 ====== */
.todo-summary {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  cursor: pointer;
}
.todo-summary:last-child { border-bottom: none; }
.todo-summary:active { opacity: 0.7; }

.todo-icon-box {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.todo-blue { background: rgba(74,144,226,0.15); }
.todo-orange { background: rgba(255,159,64,0.15); }
.todo-purple { background: rgba(108,99,255,0.15); }

.todo-info { flex: 1; min-width: 0; }
.todo-label { font-size: 15px; font-weight: 600; display: block; }
.todo-desc { font-size: 12px; color: var(--text-muted); margin-top: 2px; display: block; }

.todo-badge {
  min-width: 22px;
  height: 22px;
  border-radius: 11px;
  background: var(--primary);
  color: white;
  font-size: 12px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6px;
  flex-shrink: 0;
}

/* 待办弹窗列表 */
.todo-dialog-list {
  max-height: 55vh;
  overflow-y: auto;
}
.tdi-card {
  background: rgba(255,255,255,0.03);
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 10px;
}
.tdi-card:last-child { margin-bottom: 0; }

.tdi-row-top {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}
.tdi-icon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  flex-shrink: 0;
}
.tdi-icon-blue { background: rgba(74,144,226,0.15); }
.tdi-icon-orange { background: rgba(255,159,64,0.15); }
.tdi-icon-purple { background: rgba(108,99,255,0.15); }

.tdi-content { flex: 1; min-width: 0; }
.tdi-title { font-size: 14px; font-weight: 500; display: block; }
.tdi-pri {
  font-size: 11px;
  padding: 1px 8px;
  border-radius: 6px;
  display: inline-block;
  margin-top: 4px;
}
.tdi-pri-imp { background: rgba(243,156,18,0.15); color: var(--accent-orange); }
.tdi-pri-urgent { background: rgba(231,76,60,0.15); color: var(--accent-red); }

.tdi-status { flex-shrink: 0; }
.tdi-badge-pending, .tdi-badge-done {
  font-size: 11px;
  padding: 3px 12px;
  border-radius: 10px;
  font-weight: 500;
}
.tdi-badge-pending { background: rgba(52,152,219,0.12); color: var(--accent-blue); }
.tdi-badge-done { background: rgba(46,204,113,0.12); color: var(--accent-green); }

.tdi-row-bottom {
  display: flex;
  align-items: center;
  gap: 14px;
  padding-left: 48px;
}
.tdi-btn-done {
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 6px;
  padding: 5px 16px !important;
  font-size: 12px !important;
  font-weight: 500;
  min-height: 0 !important;
  line-height: 1.6 !important;
}
.tdi-link { font-size: 12px; color: var(--primary-light); }

/* ====== 近期活动预告 ====== */
.act-preview-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.act-preview-row:last-child { border-bottom: none; }
.ap-left { flex: 1; min-width: 0; }
.ap-date { font-size: 11px; color: var(--text-muted); display: block; }
.ap-title { font-size: 14px; font-weight: 500; display: block; margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ap-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; margin-left: 12px; }
.ap-team { font-size: 12px; color: var(--text-muted); }

/* ====== 我的待办 ====== */
.task-preview-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.task-preview-row:last-child { border-bottom: none; }
.tp-priority {
  text-align: center;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 8px;
  flex-shrink: 0;
  margin-top: 1px;
  background: rgba(108,99,255,0.12);
  color: var(--primary-light);
}
.tp-important { background: rgba(243,156,18,0.15); color: var(--accent-orange); }
.tp-urgent { background: rgba(231,76,60,0.15); color: var(--accent-red); }
.tp-info { flex: 1; min-width: 0; }
.tp-title { font-size: 14px; display: block; }
.tp-deadline { font-size: 12px; color: var(--text-muted); margin-top: 2px; display: block; }

/* ====== 骨架屏 ====== */
.skeleton-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20px 16px 100px;
  background: var(--bg-primary);
  z-index: 10;
}

.skeleton-card {
  height: 160px;
  background: linear-gradient(90deg, var(--bg-card) 25%, rgba(255,255,255,0.05) 50%, var(--bg-card) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-md);
  margin-bottom: 16px;
}

.skeleton-grid {
  display: flex;
  gap: 10px;
  margin-bottom: 16px;
}

.skeleton-square {
  flex: 1;
  height: 60px;
  background: linear-gradient(90deg, var(--bg-card) 25%, rgba(255,255,255,0.05) 50%, var(--bg-card) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}

/* ====== 动效 ====== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
