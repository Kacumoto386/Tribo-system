<!-- 首页仪表板 -->
<view class="page">
  <!-- 顶部问候 -->
  <view class="header-section" style="animation: fadeIn 0.5s;">
    <view class="header-left">
      <view class="avatar" bindtap="goProfile">
        <text class="avatar-text">{{initial}}</text>
      </view>
      <view class="greeting">
        <text class="greeting-text">{{greeting}} {{userInfo.nickname || 'Tribo 用户'}} 🧀</text>
        <text class="date-text">{{todayStr}}</text>
      </view>
    </view>
    <view class="bell-wrap" bindtap="goNotifications">
      <text class="bell-icon">🔔</text>
      <text wx:if="{{unreadCount > 0}}" class="bell-badge">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
    </view>
  </view>

  <!-- 我的团队 -->
  <view class="card" style="animation: slideUp 0.4s;">
    <view class="card-header">
      <text class="card-title">👥 我的团队</text>
      <view class="card-actions">
        <text class="card-create" bindtap="goCreateTeam">＋创建</text>
        <text class="card-more" bindtap="goTeams">全部 →</text>
      </view>
    </view>
    <view wx:for="{{teams}}" wx:key="id" class="team-row" bindtap="goTeamDetail" data-id="{{item.id}}">
      <template is="iconAvatar" data="{{initial: item.initial}}"></template>
      <view class="team-info">
        <text class="team-name">{{item.name}}</text>
        <text class="team-desc">{{item.description || ''}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view wx:if="{{teams.length === 0}}" class="empty-mini">
      <text class="empty-text-mini">还没有加入团队，去创建一个吧</text>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="quick-grid" style="animation: fadeIn 0.6s;">
    <view class="quick-item" bindtap="goGoals">
      <template is="iconBox" data="{{icon: '🎯', bgClass: 'quick-blue'}}"></template>
      <text class="quick-label">目标</text>
    </view>
    <view class="quick-item" bindtap="goTeams">
      <template is="iconBox" data="{{icon: '👥', bgClass: 'quick-orange'}}"></template>
      <text class="quick-label">团队</text>
    </view>
    <view class="quick-item" bindtap="goAchievements">
      <template is="iconBox" data="{{icon: '🏅', bgClass: 'quick-purple'}}"></template>
      <text class="quick-label">成就</text>
    </view>
  </view>

  <!-- 近期活动预告 -->
  <view class="card" wx:if="{{upcomingActivities.length > 0}}">
    <view class="card-header">
      <text class="card-title">📅 近期活动</text>
    </view>
    <view wx:for="{{upcomingActivities}}" wx:key="id" class="act-preview-row" data-id="{{item.id}}" data-team-id="{{item.team_id}}" bindtap="goActivityDetail">
      <view class="ap-left">
        <text class="ap-date">{{item._displayDate}}</text>
        <text class="ap-title">{{item.title}}</text>
      </view>
      <view class="ap-right">
        <text class="ap-team">{{item.team_name}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 我的待办（聚合三类） -->
  <view class="card" wx:if="{{todoTasks.length > 0 || todoProcs.length > 0 || todoAssigns.length > 0 || todoSetups.length > 0}}">
    <view class="card-header">
      <text class="card-title">📋 我的待办</text>
      <text class="card-more" wx:if="{{myTodos.length > 0}}">{{myTodos.length}} 项</text>
    </view>
    <view wx:if="{{todoTasks.length > 0}}" class="todo-summary" data-type="task" bindtap="showTodoDialog">
      <view class="todo-icon-box todo-blue">📋</view>
      <view class="todo-info">
        <text class="todo-label">活动任务</text>
        <text class="todo-desc">{{todoTasks.length}} 项待处理</text>
      </view>
      <text class="todo-badge">{{todoTasks.length}}</text>
    </view>
    <view wx:if="{{todoProcs.length > 0}}" class="todo-summary" data-type="procurement" bindtap="showTodoDialog">
      <view class="todo-icon-box todo-orange">🛒</view>
      <view class="todo-info">
        <text class="todo-label">采购认领</text>
        <text class="todo-desc">{{todoProcs.length}} 项待购买</text>
      </view>
      <text class="todo-badge">{{todoProcs.length}}</text>
    </view>
    <view wx:if="{{todoAssigns.length > 0}}" class="todo-summary" data-type="assign" bindtap="showTodoDialog">
      <view class="todo-icon-box todo-orange">📦</view>
      <view class="todo-info">
        <text class="todo-label">物资分派</text>
        <text class="todo-desc">{{todoAssigns.length}} 项待领取</text>
      </view>
      <text class="todo-badge">{{todoAssigns.length}}</text>
    </view>
    <view wx:if="{{todoSetups.length > 0}}" class="todo-summary" data-type="setup" bindtap="showTodoDialog">
      <view class="todo-icon-box todo-purple">🔧</view>
      <view class="todo-info">
        <text class="todo-label">布设项</text>
        <text class="todo-desc">{{todoSetups.length}} 项待完成</text>
      </view>
      <text class="todo-badge">{{todoSetups.length}}</text>
    </view>
  </view>

  <!-- 待办详情弹窗 -->
  <view wx:if="{{showTodoDialog}}" class="dialog-mask" bindtap="closeTodoDialog">
    <view class="dialog-box dialog-wide" catchtap>
      <view class="dialog-header">
        <text class="dialog-title">{{todoDialogType === 'task' ? '📋 活动任务' : todoDialogType === 'procurement' ? '🛒 采购认领' : todoDialogType === 'assign' ? '📦 物资分派' : '🔧 布设项'}}</text>
        <text class="dialog-close" bindtap="closeTodoDialog">✕</text>
      </view>
      <view class="todo-dialog-list">
        <view wx:for="{{todoDialogList}}" wx:key="index" class="tdi-card">
          <view class="tdi-row-top">
            <view class="tdi-icon {{todoDialogType === 'task' ? 'tdi-icon-blue' : todoDialogType === 'procurement' || todoDialogType === 'assign' ? 'tdi-icon-orange' : 'tdi-icon-purple'}}">
              <text>{{todoDialogType === 'task' ? '📋' : todoDialogType === 'procurement' ? '🛒' : todoDialogType === 'assign' ? '📦' : '🔧'}}</text>
            </view>
            <view class="tdi-content">
              <text class="tdi-title">{{item.title}}</text>
              <text wx:if="{{item.priority > 0}}" class="tdi-pri {{item.priority === 2 ? 'tdi-pri-urgent' : 'tdi-pri-imp'}}">
                {{['','重要','紧急'][item.priority] || ''}}
              </text>
            </view>
            <view class="tdi-status {{item.status === 0 ? 'tdi-badge-pending' : 'tdi-badge-done'}}">
              <text>{{['待处理','进行中','已完成'][item.status] || '待处理'}}</text>
            </view>
          </view>
          <view class="tdi-row-bottom">
            <button class="tdi-btn-done" size="mini" data-item="{{item}}" bindtap="completeTodoItem">✓ 标记完成</button>
            <text class="tdi-link" data-id="{{item.activity_id}}" data-team-id="{{item.team_id}}" data-type="{{item.type}}" bindtap="goTaskDetail">查看详情 →</text>
          </view>
        </view>
        <view wx:if="{{todoDialogList.length === 0}}" class="empty-state">
          <text class="empty-text">暂无待办</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view style="height: 40px;"></view>

  <!-- ====== 模板：头像图标（背景+图案一体） ====== -->
  <template name="iconAvatar">
    <view class="team-avatar">
      <text class="team-avatar-text">{{initial}}</text>
    </view>
  </template>

  <!-- ====== 模板：方形图标（背景+emoji一体） ====== -->
  <template name="iconBox">
    <view class="icon-box {{bgClass}}">
      <text class="icon-box-text">{{icon}}</text>
    </view>
  </template>

  <!-- 加载骨架 -->
  <view wx:if="{{loading}}" class="skeleton-overlay">
    <view class="skeleton-card"></view>
    <view class="skeleton-grid">
      <view class="skeleton-square"></view>
      <view class="skeleton-square"></view>
      <view class="skeleton-square"></view>
    </view>
    <view class="skeleton-card"></view>
  </view>
</view>
