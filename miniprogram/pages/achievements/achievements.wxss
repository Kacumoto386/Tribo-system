.page {
  padding: 20px 0 100px;
}

/* 顶部统计 */
.stats-card {
  text-align: center;
  padding: 24px;
}

.ach-stats {
  margin-bottom: 12px;
}

.ach-stat-value {
  font-size: 36px;
  font-weight: 700;
  color: var(--primary-light);
  display: block;
}

.ach-stat-label {
  font-size: 14px;
  color: var(--text-muted);
  margin-top: 4px;
  display: block;
}

.ach-progress-ring {
  width: 80%;
  height: 8px;
  background: rgba(255,255,255,0.08);
  border-radius: 4px;
  margin: 0 auto;
  overflow: hidden;
}

.ring-bg {
  height: 100%;
  border-radius: 4px;
}

.ring-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), #ff6b9d);
  border-radius: 4px;
  transition: width 0.5s;
}

/* 分类筛选 */
.filter-row {
  display: flex;
  gap: 6px;
  padding: 0 16px 12px;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 8px;
  border-radius: var(--radius-sm);
  background: var(--bg-card);
  font-size: 13px;
  color: var(--text-secondary);
}

.filter-active {
  background: var(--primary);
  color: white;
  font-weight: 600;
}

/* 成就卡片 */
.ach-card {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
  padding: 14px 16px;
}

.ach-locked {
  opacity: 0.5;
}

.ach-icon-box {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 24px;
}

.ach-unlocked {
  background: linear-gradient(135deg, var(--primary), #ff6b9d);
}

.ach-locked-icon {
  background: rgba(255,255,255,0.06);
}

.ach-info {
  flex: 1;
}

.ach-name {
  font-size: 15px;
  font-weight: 600;
  display: block;
}

.ach-desc {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 2px;
  display: block;
}

.empty-state {
  text-align: center;
  padding: 40px 16px;
}

.empty-text {
  font-size: 14px;
  color: var(--text-muted);
}
