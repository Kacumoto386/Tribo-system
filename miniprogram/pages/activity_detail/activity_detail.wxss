.page { padding: 0 0 100px; }

.dialog-box {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 20px;
  max-height: 85vh;
  overflow-y: auto;
}

.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 8vh;
  z-index: 999;
}

/* 活动头部 */
.activity-header {
  padding: 0 16px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.ah-title {
  font-size: 20px;
  font-weight: 700;
  display: block;
  margin-bottom: 8px;
}
.ah-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 6px;
}
.ah-meta {
  font-size: 13px;
  color: var(--text-secondary);
}
.ah-desc {
  font-size: 14px;
  color: var(--text-secondary);
  margin-top: 8px;
  line-height: 1.6;
}
.ah-stats {
  display: flex;
  gap: 20px;
  margin-top: 10px;
}
.ah-stat {
  font-size: 13px;
  color: var(--text-muted);
}

/* Tab */
.tab-row {
  display: flex;
  gap: 0;
  padding: 12px 16px 0;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 10px;
  font-size: 14px;
  color: var(--text-secondary);
  border-bottom: 2px solid transparent;
}
.tab-active {
  color: var(--primary-light);
  border-bottom-color: var(--primary);
  font-weight: 600;
}

/* 参与人 */
.participant-section {
  padding: 16px;
}
.p-section-title {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 10px;
  display: block;
}
.participant-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.pi-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(108,99,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  color: var(--primary-light);
  flex-shrink: 0;
}
.pi-name {
  flex: 1;
  font-size: 13px;
}
.pi-status {
  font-size: 12px;
}

/* 评论 */
.comment-section {
  padding: 0 16px 16px;
}
.comment-item {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
  font-size: 13px;
}
.comment-user {
  color: var(--primary-light);
  font-weight: 500;
  flex-shrink: 0;
}
.comment-text {
  color: var(--text-primary);
  flex: 1;
}
.comment-input-row {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}
.comment-input {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 8px 12px;
  font-size: 13px;
  color: var(--text-primary);
  height: 36px;
}

/* ===== 物资 ===== */
.resource-card {
  margin-bottom: 10px;
}
.rc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}
.rc-name {
  font-size: 15px;
  font-weight: 600;
}
.rc-meta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 6px;
}
.rc-progress {
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 2px;
  margin-bottom: 8px;
  overflow: hidden;
}
.rc-progress-bar {
  height: 100%;
  background: var(--primary);
  border-radius: 2px;
  transition: width 0.3s;
}
.rc-actions {
  display: flex;
  gap: 8px;
  margin-top: 6px;
}
.rc-assign-item {
  font-size: 12px;
  color: var(--text-secondary);
  padding: 4px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

/* ===== 场地 ===== */
.venue-card {
  margin-bottom: 10px;
}
.vc-field {
  display: flex;
  gap: 8px;
  margin-bottom: 6px;
  font-size: 13px;
}
.vc-label {
  color: var(--text-muted);
  flex-shrink: 0;
}
.vc-value {
  color: var(--text-primary);
  flex: 1;
}
.vc-actions {
  display: flex;
  gap: 8px;
  margin-top: 10px;
}

/* 布设子项 */
.setup-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.si-check {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid var(--border);
  flex-shrink: 0;
}
.si-check.done {
  background: var(--primary);
  border-color: var(--primary);
  position: relative;
}
.si-check.done::after {
  content: '✓';
  color: white;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.si-info {
  flex: 1;
}
.si-name {
  font-size: 14px;
  font-weight: 500;
  display: block;
}
.si-assignee {
  font-size: 12px;
  color: var(--text-muted);
  display: block;
  margin-top: 2px;
}

/* ===== 任务 ===== */
.task-card {
  margin-bottom: 8px;
}
.tc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}
.tc-title {
  font-size: 15px;
  font-weight: 600;
  flex: 1;
}
.tc-meta {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 4px;
}
.tc-desc {
  font-size: 13px;
  color: var(--text-secondary);
  padding: 6px 0;
}
.tc-actions {
  display: flex;
  gap: 6px;
  margin-top: 6px;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 40px 16px;
}
.empty-text {
  font-size: 15px;
  color: var(--text-secondary);
}
.empty-sub {
  font-size: 13px;
  color: var(--text-muted);
  margin-top: 6px;
  display: block;
}

/* 添加按钮 */
.add-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  border: 2px dashed var(--border);
  margin-bottom: 10px;
}
.add-icon {
  font-size: 16px;
}
.add-text {
  font-size: 13px;
  color: var(--text-muted);
}

/* 表单 */
.form-group { margin-bottom: 14px; }
.form-label { font-size: 13px; color: var(--text-secondary); margin-bottom: 4px; display: block; }
.input-field {
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  font-size: 14px;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
}
.picker-value {
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  font-size: 14px;
  color: var(--text-primary);
}
.dialog-wide { width: 90%; max-width: 400px; }
.small-btn { padding: 4px 10px; font-size: 12px; }

/* 弹窗专用 */
.dialog-scroll {
  max-height: 70vh;
  overflow-y: auto;
}

/* 成员多选列表 */
.member-check-list {
  max-height: 40vh;
  overflow-y: auto;
  background: rgba(255,255,255,0.03);
  border-radius: var(--radius-sm);
  padding: 4px 0;
}
.member-check-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.member-check-row:last-child { border-bottom: none; }
.member-check-row:active { background: rgba(108,99,255,0.08); }
.member-check-box { font-size: 18px; width: 22px; text-align: center; flex-shrink: 0; }
.member-check-label { font-size: 14px; color: var(--text-primary); }

/* ===== 采购 ===== */
.proc-card {
  margin-bottom: 10px;
}
.pc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}
.pc-name {
  font-size: 15px;
  font-weight: 600;
}
.pc-meta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 4px;
}
.pc-actions {
  display: flex;
  gap: 8px;
  margin-top: 6px;
}
.pc-claim-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12px;
  color: var(--text-secondary);
  padding: 4px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.pci-left {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
}
.pci-cost {
  color: var(--primary);
  font-weight: 500;
}
.pci-actions {
  display: flex;
  gap: 4px;
  align-items: center;
}

/* 统计 */
.stats-summary-card {
  margin-bottom: 10px;
}
.stats-title {
  font-size: 15px;
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
}
.stats-row {
  display: flex;
  gap: 8px;
  margin-bottom: 4px;
  font-size: 14px;
  align-items: baseline;
}
.stats-label {
  color: var(--text-muted);
}
.stats-value {
  font-weight: 600;
}
.stats-value.muted { color: var(--text-secondary); }
.stats-value.primary { color: var(--primary-light); }
.stats-value.accent { color: #ff9800; }
.stats-note {
  font-size: 12px;
  color: var(--text-muted);
}
.stats-warning {
  margin-bottom: 10px;
  font-size: 13px;
  color: #ff9800;
  border: 1px solid rgba(255,152,0,0.2);
}
.person-row {
  display: flex;
  gap: 8px;
  padding: 6px 0;
  font-size: 13px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  flex-wrap: wrap;
}
.person-name {
  flex: 1;
  font-weight: 500;
  min-width: 60px;
}
.person-spent {
  width: 80px;
  text-align: right;
}
.person-share {
  width: 80px;
  text-align: right;
  color: var(--text-muted);
}
.person-balance {
  width: 100px;
  text-align: right;
  font-weight: 600;
}
.person-balance.positive { color: #4caf50; }
.person-balance.negative { color: #f44336; }
