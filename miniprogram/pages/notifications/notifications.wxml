<view class="page">
  <view class="notif-header">
    <text class="notif-title">通知</text>
    <text class="notif-mark-all" bindtap="markAllRead">全部已读</text>
  </view>

  <view wx:for="{{notifications}}" wx:key="id" class="card notif-card {{item.is_read ? 'notif-read' : ''}}"
        data-item="{{item}}" bindtap="onTapNotification">
    <view class="notif-row">
      <text class="notif-icon">
        {{item.type === 'signup_confirmed' ? '📝' :
          item.type === 'checkin_confirmed' ? '✅' :
          item.type === 'new_comment' ? '💬' :
          item.type === 'new_announcement' ? '📢' : '🔔'}}
      </text>
      <view class="notif-info">
        <view class="notif-title-row">
          <text class="notif-title-text">{{item.title}}</text>
          <view wx:if="{{!item.is_read}}" class="tag tag-primary notif-unread-tag">新</view>
        </view>
        <text wx:if="{{item.body}}" class="notif-body">{{item.body}}</text>
        <text class="notif-time">{{item.created_at}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{notifications.length === 0 && !loading}}" class="empty-state">
    <text class="empty-text">暂无通知</text>
  </view>
</view>
