.page { padding: 20px 0 100px; }

.notif-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px 16px;
}

.notif-title { font-size: 20px; font-weight: 700; }

.notif-mark-all {
  font-size: 14px;
  color: var(--primary-light);
}

.notif-card {
  margin-bottom: 8px;
  opacity: 0.8;
}

.notif-read {
  opacity: 0.5;
}

.notif-row {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.notif-icon { font-size: 24px; }

.notif-info { flex: 1; }

.notif-title-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.notif-title-text {
  font-size: 15px;
  font-weight: 500;
}

.notif-unread-tag { font-size: 10px; padding: 2px 6px; }

.notif-body {
  font-size: 13px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4px;
}

.notif-time {
  font-size: 12px;
  color: var(--text-muted);
  display: block;
}

.empty-state {
  text-align: center;
  padding: 60px 16px;
}

.empty-text { font-size: 16px; color: var(--text-secondary); }
