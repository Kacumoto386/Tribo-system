<!-- 专项挑战详情 -->
<view class="page">
  <!-- 头部进度卡片 -->
  <view class="card progress-card">
    <view class="pc-header">
      <view class="pc-type-tag">{{event.typeTag}}</view>
      <text class="tag {{['tag-info','tag-warning','tag-success','tag-danger'][event.status] || 'tag-info'}}">
        {{['准备中','进行中','已完成','已取消'][event.status] || '准备中'}}
      </text>
    </view>
    <text class="pc-title">{{event.title}}</text>
    <view class="pc-ring-section">
      <view class="pc-ring" bindtap="logProgress">
        <canvas type="2d" id="progressRing" class="pc-canvas"></canvas>
        <view class="pc-ring-center">
          <text class="pc-ring-pct">{{event.progress_percent || 0}}%</text>
          <text class="pc-ring-label">点击打卡</text>
        </view>
      </view>
    </view>
    <view class="pc-stats">
      <view class="pc-stat">
        <text class="pc-stat-value">{{event.current_value || 0}}</text>
        <text class="pc-stat-label">当前 / {{event.unit || ''}}</text>
      </view>
      <view class="pc-stat">
        <text class="pc-stat-value">{{event.goal_value}}</text>
        <text class="pc-stat-label">目标 / {{event.unit || ''}}</text>
      </view>
      <view class="pc-stat">
        <text class="pc-stat-value">{{stats.total_logs || 0}}</text>
        <text class="pc-stat-label">打卡次数</text>
      </view>
    </view>
  </view>

  <!-- 描述 -->
  <view wx:if="{{event.description}}" class="card desc-card">
    <text class="desc-text">{{event.description}}</text>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-row">
    <view wx:for="{{['打卡记录','排行榜']}}" wx:key="index"
          class="tab-item {{currentTab === index ? 'tab-active' : ''}}"
          data-index="{{index}}" bindtap="switchTab">
      <text>{{item}}</text>
    </view>
  </view>

  <!-- 打卡记录 -->
  <view wx:if="{{currentTab === 0}}">
    <view wx:for="{{logs}}" wx:key="id" class="card log-card">
      <view class="lc-left">
        <text class="lc-icon">🏃</text>
        <view>
          <text class="lc-value">+{{item.value}} {{event.unit || ''}}</text>
          <text class="lc-date">{{item.log_date}}</text>
        </view>
      </view>
      <text wx:if="{{item.note}}" class="lc-note">{{item.note}}</text>
    </view>
    <view wx:if="{{logs.length === 0}}" class="empty-state">
      <text class="empty-text">暂无打卡记录</text>
      <text class="empty-sub">点击进度圆环开始打卡吧！</text>
    </view>
  </view>

  <!-- 排行榜 -->
  <view wx:if="{{currentTab === 1}}">
    <view wx:for="{{rankings}}" wx:key="id" class="card ranking-card">
      <text class="rk-rank {{item.rank_no <= 3 ? 'rk-top' : ''}}">#{{item.rank_no}}</text>
      <view class="rk-avatar">{{item.initial}}</view>
      <view class="rk-info">
        <text class="rk-name">{{item.user_id}}</text>
        <text class="rk-value">{{item.total_value}} {{event.unit || ''}}</text>
      </view>
      <text wx:if="{{item.rank_no === 1}}" class="rk-badge">🥇</text>
      <text wx:elif="{{item.rank_no === 2}}" class="rk-badge">🥈</text>
      <text wx:elif="{{item.rank_no === 3}}" class="rk-badge">🥉</text>
    </view>
    <view wx:if="{{rankings.length === 0}}" class="empty-state">
      <text class="empty-text">暂无排行榜</text>
    </view>
  </view>

  <!-- 打卡弹窗 -->
  <view wx:if="{{showLog}}" class="dialog-mask" bindtap="closeLog">
    <view class="dialog-box" catchtap>
      <view class="dialog-header">
        <text class="dialog-title">🏃 打卡</text>
        <text class="dialog-close" bindtap="closeLog">✕</text>
      </view>
      <view class="form-group">
        <text class="form-label">本次值 * ({{event.unit || ''}})</text>
        <input class="input-field" type="digit" placeholder="如：5" value="{{logForm.value}}" bindinput="onLogInput" data-field="value" />
      </view>
      <view class="form-group">
        <text class="form-label">备注</text>
        <input class="input-field" placeholder="可选" value="{{logForm.note}}" bindinput="onLogInput" data-field="note" />
      </view>
      <button class="btn-primary" bindtap="submitLog" loading="{{submittingLog}}">✅ 打卡</button>
    </view>
  </view>
</view>
