page {
  --primary: #6c63ff;
  --primary-light: #8b83ff;
  --primary-dark: #4a42e0;
  --bg-dark: #1a1a2e;
  --bg-card: #16213e;
  --bg-card-hover: #1f2f50;
  --text-primary: #ffffff;
  --text-secondary: #a0a0b8;
  --text-muted: #6c6c80;
  --accent-green: #2ecc71;
  --accent-orange: #f39c12;
  --accent-red: #e74c3c;
  --accent-blue: #3498db;
  --border: #2a2a4a;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow: 0 4px 12px rgba(0,0,0,0.3);
  background: var(--bg-dark);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
}

/* 通用卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 16px;
  margin: 0 16px 12px;
  box-shadow: var(--shadow);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
  border: none;
  border-radius: var(--radius-sm);
  padding: 12px 24px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  background: transparent;
  color: var(--primary-light);
  border: 1px solid var(--primary);
  border-radius: var(--radius-sm);
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
}

/* 输入框 */
.input-field {
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  font-size: 16px;
  color: var(--text-primary);
  width: 100%;
  min-height: 48px;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: var(--primary);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
}

.tag-success { background: rgba(46,204,113,0.15); color: var(--accent-green); }
.tag-warning { background: rgba(243,156,18,0.15); color: var(--accent-orange); }
.tag-danger { background: rgba(231,76,60,0.15); color: var(--accent-red); }
.tag-info { background: rgba(52,152,219,0.15); color: var(--accent-blue); }
.tag-primary { background: rgba(108,99,255,0.15); color: var(--primary-light); }

/* 统计数字 */
.stat-number {
  font-size: 28px;
  font-weight: 700;
  color: var(--primary-light);
}

.stat-label {
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 2px;
}

/* ====== 全局动效 ====== */
.fade-in {
  animation: fadeIn 0.4s ease-out both;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-up {
  animation: slideUp 0.35s ease-out both;
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ====== 全局空状态 ====== */
.empty-block {
  text-align: center;
  padding: 40px 16px;
}
.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}
.empty-title {
  font-size: 16px;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4px;
}
.empty-desc {
  font-size: 13px;
  color: var(--text-muted);
  display: block;
}

/* ====== 骨架屏 ====== */
.skel-card {
  height: 100px;
  background: linear-gradient(90deg, var(--bg-card) 25%, rgba(255,255,255,0.04) 50%, var(--bg-card) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius);
  margin: 0 16px 12px;
}
.skel-line {
  height: 14px;
  width: 60%;
  background: linear-gradient(90deg, var(--bg-card) 25%, rgba(255,255,255,0.04) 50%, var(--bg-card) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 7px;
  margin: 8px 16px;
}
.skel-line-s {
  width: 40%;
}
.skel-line-l {
  width: 80%;
}
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
